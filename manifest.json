{
  "manifest_version": 3,
  "name": "Quiet Apply",
  "version": "1.0",
  "description": "Apply smarter, not louder.",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  }
}
